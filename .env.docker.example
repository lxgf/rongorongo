APP_NAME=Rongorongo
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://localhost:2020

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

LOG_CHANNEL=stderr
LOG_LEVEL=error

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=rongorongo
DB_USERNAME=rongorongo
DB_PASSWORD=secret

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Sessions via Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=redis

# Mail (change for production)
MAIL_MAILER=log
